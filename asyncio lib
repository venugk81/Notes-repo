2 — The big win: fetch multiple URLs concurrently
python# ❌ REQUESTS — sequential, slow (waits for each one)
import requests, time

urls = [f"https://jsonplaceholder.typicode.com/posts/{i}" for i in range(1, 6)]

start = time.time()
for url in urls:
    r = requests.get(url)
    print(r.json()["title"])
print(f"Time: {time.time() - start:.2f}s")   # ~2.5s (0.5s × 5 requests)
python# ✅ AIOHTTP — concurrent, fast (all requests in flight at once)
import asyncio, aiohttp, time

async def fetch_post(session, post_id):
    url = f"https://jsonplaceholder.typicode.com/posts/{post_id}"
    async with session.get(url) as response:
        data = await response.json()
        return data["title"]

async def main():
    start = time.time()

    async with aiohttp.ClientSession() as session:
        tasks = [fetch_post(session, i) for i in range(1, 6)]
        titles = await asyncio.gather(*tasks)   # all 5 fire at once

    for title in titles:
        print(title)
    print(f"Time: {time.time() - start:.2f}s")  # ~0.3s — 8x faster!

asyncio.run(main())

