        async with sem:
            result = await process_item(item_id)
            print(f"  ✓ item {item_id:2d} done | value={result['value']}")
            return result

    tasks = [asyncio.create_task(bounded(i)) for i in items]
    results = await asyncio.gather(*tasks)

    print(f"\nAll done in {time.time() - start:.2f}s")
    print(f"Results: {[r['value'] for r in results]}")

