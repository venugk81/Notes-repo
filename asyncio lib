12 — asyncio.current_task() & callbacks
pythonimport asyncio

async def tracked_worker(task_id):
    current = asyncio.current_task()
    print(f"  [{current.get_name()}] worker {task_id} starting")
    await asyncio.sleep(1)
    return task_id * 100

def on_done(task):
    if task.cancelled():
        print(f"  {task.get_name()} was cancelled")
    elif task.exception():
        print(f"  {task.get_name()} raised: {task.exception()}")
    else:
        print(f"  {task.get_name()} finished → {task.result()}")

async def main():
    tasks = []
    for i in range(1, 4):
        t = asyncio.create_task(tracked_worker(i), name=f"worker-{i}")
        t.add_done_callback(on_done)    # fires when task completes
        tasks.append(t)

    await asyncio.gather(*tasks)

asyncio.run(main())

13 — Complete concurrency toolkit: everything together
A realistic example that combines TaskGroup, Semaphore, as_completed, timeouts and error handling into one pattern you can adapt for production:
pythonimport asyncio, time, random

# Simulates an API call that sometimes fails or is slow
async def api_call(endpoint, item_id):
    delay = random.uniform(0.3, 1.5)
    await asyncio.sleep(delay)

    if random.random() < 0.2:               # 20% failure rate
        raise ConnectionError(f"{endpoint}/{item_id} failed")

    return {"endpoint": endpoint, "id": item_id, "delay": round(delay, 2)}

async def safe_call(session_sem, endpoint, item_id, timeout=2.0):
    async with session_sem:                 # rate limit
        try:
            return await asyncio.wait_for(
                api_call(endpoint, item_id),
                timeout=timeout
            )
        except asyncio.TimeoutError:
            return {"error": "timeout", "id": item_id}
        except ConnectionError as e:
            return {"error": str(e),    "id": item_id}

async def main():
    sem       = asyncio.Semaphore(4)        # 4 concurrent max
    endpoints = ["users", "orders", "products"]
    item_ids  = range(1, 7)                 # 6 items each = 18 total calls

    start  = time.time()
    ok     = []
    errors = []

    coros = [
        safe_call(sem, ep, iid)
        for ep in endpoints
        for iid in item_ids
    ]

    print(f"Firing {len(coros)} requests (max 4 concurrent)...\n")

    for future in asyncio.as_completed(coros):
        result = await future
        if "error" in result:
            errors.append(result)
            print(f"  ✗ error  — {result['error']}")
        else:
            ok.append(result)
            print(f"  ✓ ok     — {result['endpoint']}/{result['id']} in {result['delay']}s")

    elapsed = time.time() - start
    print(f"\n{'─'*45}")
    print(f"  Total:   {len(coros)} requests in {elapsed:.2f}s")
    print(f"  Success: {len(ok)}")
    print(f"  Errors:  {len(errors)}")
    print(f"  Speedup: ~{len(coros) * 0.9 / elapsed:.1f}x vs sequential")

asyncio.run(main())

Full concurrency primitives map
asyncio.create_task()     → schedule a coroutine, get a Task back
asyncio.gather()          → run N awaitables, get all results in order
asyncio.wait()            → run N tasks, get (done, pending) sets
asyncio.as_completed()    → iterate results as they finish
asyncio.wait_for()        → add a timeout to any awaitable
asyncio.shield()          → protect a task from cancellation
asyncio.TaskGroup         → structured concurrency (Python 3.11+)
asyncio.sleep(0)          → yield control to the event loop
asyncio.all_tasks()       → inspect every running task
asyncio.current_task()    → get the currently running task

