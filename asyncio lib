10 — asyncio.TaskGroup — the modern way (Python 3.11+)
TaskGroup is the safest way to manage multiple tasks. It replaces the gather() + manual cancellation pattern with a clean context manager. If any task raises, all others are cancelled automatically.
pythonimport asyncio

async def worker(name, delay, fail=False):
    await asyncio.sleep(delay)
    if fail:
        raise ValueError(f"{name} failed!")
    return f"{name}_done"

async def main():
    results = []

    async with asyncio.TaskGroup() as tg:
        t1 = tg.create_task(worker("alpha",   1))
        t2 = tg.create_task(worker("beta",    2))
        t3 = tg.create_task(worker("gamma",   1))
        # All 3 run concurrently
        # TaskGroup waits for ALL to finish before exiting the block

    # Results available after the 'async with' block
    results = [t1.result(), t2.result(), t3.result()]
    print(results)   # ['alpha_done', 'beta_done', 'gamma_done']

asyncio.run(main())
TaskGroup error handling — automatic cleanup
pythonimport asyncio

async def job(name, delay, fail=False):
    try:
        await asyncio.sleep(delay)
        if fail:
            raise RuntimeError(f"{name} exploded")
        print(f"  {name}: completed")
        return name
    except asyncio.CancelledError:
        print(f"  {name}: was cancelled (cleanup here)")
        raise

async def main():
    try:
        async with asyncio.TaskGroup() as tg:
            tg.create_task(job("A", 1))
            tg.create_task(job("B", 2, fail=True))  # this will fail
            tg.create_task(job("C", 3))
        # B fails at t=2 → A completes, C is cancelled automatically

    except* RuntimeError as eg:
        # Python 3.11+ ExceptionGroup syntax
        for e in eg.exceptions:
            print(f"Caught: {e}")

asyncio.run(main())
