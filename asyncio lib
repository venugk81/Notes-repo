6 — asyncio.wait_for() — timeout a single task
pythonimport asyncio

async def slow_api_call():
    await asyncio.sleep(10)       # simulates a very slow response
    return "data"

async def main():
    # Approach 1 — raises TimeoutError after N seconds
    try:
        result = await asyncio.wait_for(slow_api_call(), timeout=3.0)
    except asyncio.TimeoutError:
        print("Timed out after 3s!")

    # Approach 2 — timeout with a fallback value
    async def with_fallback(coro, timeout, fallback):
        try:
            return await asyncio.wait_for(coro, timeout)
        except asyncio.TimeoutError:
            return fallback

    result = await with_fallback(slow_api_call(), timeout=2.0, fallback="default")
    print(f"Got: {result}")     # "default"

asyncio.run(main())

7 — asyncio.shield() — protect a task from cancellation
pythonimport asyncio

async def critical_save():
    print("  save: started (cannot be interrupted!)")
    await asyncio.sleep(3)
    print("  save: completed safely")
    return "saved"

async def main():
    task = asyncio.create_task(critical_save())

    try:
        # shield() protects critical_save from being cancelled
        # if wait_for times out, only the shield wrapper is cancelled
        result = await asyncio.wait_for(asyncio.shield(task), timeout=1.0)
    except asyncio.TimeoutError:
        print("wait_for timed out — but critical_save is still running!")

    await task    # wait for it to finish naturally
    print(f"Result: {task.result()}")

asyncio.run(main())

