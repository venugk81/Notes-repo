All done in 2.10s     ← vs ~8s sequential

9 — asyncio.as_completed() — process results as they arrive
gather() waits for ALL tasks. as_completed() gives you each result the moment it's ready — perfect for showing progress or acting on early results.
pythonimport asyncio, time

async def fetch(name, delay):
    await asyncio.sleep(delay)
    return f"{name} (took {delay}s)"

async def main():
    coros = [
        fetch("slow",    3),
        fetch("fast",    1),
        fetch("medium",  2),
        fetch("instant", 0.5),
    ]

    print("Results arriving in completion order:\n")
    start = time.time()

    # as_completed yields futures in the order they FINISH, not the order listed
    for future in asyncio.as_completed(coros):
        result = await future
        elapsed = time.time() - start
        print(f"  [{elapsed:.1f}s] Got: {result}")

asyncio.run(main())
