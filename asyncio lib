5 — Error handling
pythonimport asyncio
import aiohttp

async def safe_fetch(url):
    try:
        async with aiohttp.ClientSession() as session:
            async with session.get(url, timeout=aiohttp.ClientTimeout(total=5)) as r:
                r.raise_for_status()
                return await r.json()

    except aiohttp.ClientConnectionError:
        print("Connection failed")

    except aiohttp.ClientResponseError as e:
        print(f"HTTP error: {e.status}")         # 404, 500, etc.

    except asyncio.TimeoutError:
        print("Request timed out")

    except aiohttp.ClientError as e:
        print(f"Something went wrong: {e}")      # catches all aiohttp errors

async def main():
    # valid request
    data = await safe_fetch("https://jsonplaceholder.typicode.com/posts/1")
    print(data["title"])

    # 404 — will print "HTTP error: 404"
    await safe_fetch("https://jsonplaceholder.typicode.com/posts/99999")

    # timeout — change total=0.0001 to trigger it
    await safe_fetch("https://jsonplaceholder.typicode.com/posts/1")

asyncio.run(main())

6 — Fetch with retries (real-world pattern)
pythonimport asyncio
import aiohttp

async def fetch_with_retry(session, url, retries=3, delay=1):
    for attempt in range(1, retries + 1):
        try:
            async with session.get(url, timeout=aiohttp.ClientTimeout(total=5)) as r:
                r.raise_for_status()
                return await r.json()

        except (aiohttp.ClientError, asyncio.TimeoutError) as e:
            print(f"Attempt {attempt} failed: {e}")
            if attempt < retries:
                await asyncio.sleep(delay * attempt)   # exponential backoff
            else:
                raise

async def main():
    async with aiohttp.ClientSession() as session:
        data = await fetch_with_retry(
            session,
            "https://jsonplaceholder.typicode.com/posts/1"
        )
        print(data["title"])

asyncio.run(main())

7 — Rate-limited concurrent requests (Semaphore)
Firing 100 requests at once can get you blocked. Use asyncio.Semaphore to cap concurrency:
pythonimport asyncio
import aiohttp

async def fetch(session, sem, post_id):
    url = f"https://jsonplaceholder.typicode.com/posts/{post_id}"
    async with sem:                              # only N requests at a time
        async with session.get(url) as r:
            data = await r.json()
            print(f"Post {post_id}: {data['title'][:40]}")
            return data

async def main():
    sem = asyncio.Semaphore(5)                   # max 5 concurrent requests

    async with aiohttp.ClientSession() as session:
        tasks = [fetch(session, sem, i) for i in range(1, 21)]  # 20 posts
        results = await asyncio.gather(*tasks)
    
    print(f"\nFetched {len(results)} posts")

asyncio.run(main())

