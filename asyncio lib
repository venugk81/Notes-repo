gather() with error handling
pythonimport asyncio

async def risky(name, should_fail=False):
    await asyncio.sleep(0.5)
    if should_fail:
        raise ValueError(f"{name} exploded!")
    return f"{name}_ok"

async def main():
    # Default — first exception cancels everything and propagates
    try:
        results = await asyncio.gather(
            risky("A"),
            risky("B", should_fail=True),
            risky("C"),
        )
    except ValueError as e:
        print(f"gather failed: {e}")    # B's error surfaces here

    # return_exceptions=True — exceptions returned as values, nothing cancelled
    results = await asyncio.gather(
        risky("A"),
        risky("B", should_fail=True),
        risky("C"),
        return_exceptions=True          # ← key flag
    )
    for r in results:
        if isinstance(r, Exception):
            print(f"Error: {r}")
        else:
            print(f"OK:    {r}")

asyncio.run(main())

4 — asyncio.wait() — fine-grained control
pythonimport asyncio

async def job(name, delay):
    await asyncio.sleep(delay)
    return name

async def main():
    tasks = {
        asyncio.create_task(job("fast",   1), name="fast"),
        asyncio.create_task(job("medium", 2), name="medium"),
        asyncio.create_task(job("slow",   3), name="slow"),
    }

    # Wait until ALL are done
    done, pending = await asyncio.wait(tasks, return_when=asyncio.ALL_COMPLETED)
    print(f"All done: {[t.result() for t in done]}")

    # Reset tasks
    tasks = {
        asyncio.create_task(job("fast",   1), name="fast"),
        asyncio.create_task(job("medium", 2), name="medium"),
        asyncio.create_task(job("slow",   3), name="slow"),
    }

    # Stop as soon as the FIRST one finishes
    done, pending = await asyncio.wait(tasks, return_when=asyncio.FIRST_COMPLETED)
    winner = done.pop()
    print(f"First done: {winner.result()}")

    # Cancel the rest
    for t in pending:
        t.cancel()
    await asyncio.gather(*pending, return_exceptions=True)

asyncio.run(main())
