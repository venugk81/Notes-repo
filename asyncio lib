1 — asyncio.create_task() — the most important primitive
pythonimport asyncio

async def worker(name, delay):
    print(f"  {name}: started")
    await asyncio.sleep(delay)
    print(f"  {name}: done")
    return f"result_from_{name}"

async def main():
    # WITHOUT create_task — sequential (like Session 1's plain await)
    await worker("A", 2)    # waits 2s
    await worker("B", 1)    # then waits 1s → total 3s

    # WITH create_task — concurrent, scheduled immediately
    task_a = asyncio.create_task(worker("A", 2))   # schedules A now
    task_b = asyncio.create_task(worker("B", 1))   # schedules B now

    result_a = await task_a   # waits for A, but B is already running!
    result_b = await task_b   # B is likely done already
    print(result_a, result_b)

asyncio.run(main())
Critical insight: create_task() schedules the coroutine on the event loop immediately. The task starts running as soon as the current coroutine hits any await.

2 — Task lifecycle & cancellation
pythonimport asyncio

async def long_job():
    try:
        print("  job: started")
        await asyncio.sleep(10)         # simulates long work
        print("  job: finished")        # never reached if cancelled
        return "done"
    except asyncio.CancelledError:
        print("  job: I was cancelled! cleaning up...")
        raise                           # always re-raise CancelledError

async def main():
    task = asyncio.create_task(long_job())

    await asyncio.sleep(2)              # let it run for 2 seconds

    # inspect the task
    print(f"Done?      {task.done()}")       # False
    print(f"Cancelled? {task.cancelled()}") # False

    task.cancel()                       # send cancellation signal
    await asyncio.sleep(0)             # give loop a tick to process it

    print(f"Done?      {task.done()}")       # True
    print(f"Cancelled? {task.cancelled()}") # True

asyncio.run(main())

