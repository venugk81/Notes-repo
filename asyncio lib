Example 3 — Understanding the event loop directly
pythonimport asyncio

async def task_a():
    print("A: start")
    await asyncio.sleep(2)
    print("A: end")

async def task_b():
    print("B: start")
    await asyncio.sleep(1)
    print("B: end")

async def main():
    loop = asyncio.get_event_loop()
    print(f"Running loop: {loop}")

    # The moment you 'await', control returns to the loop
    # The loop picks the next ready coroutine and runs it
    await asyncio.gather(task_a(), task_b())

asyncio.run(main())
# Output order: A:start → B:start → B:end → A:end
The event loop follows this cycle:
┌─────────────────────────────────────┐
│  1. Pick the next ready coroutine   │
│  2. Run it until it hits an await   │
│  3. Check if any I/O is done        │
│  4. Wake up coroutines that can go  │
│  5. Repeat                          │
└─────────────────────────────────────┘

Example 4 — async def vs regular def: the critical difference
pythonimport asyncio

def sync_function():
    return 42                   # returns a value directly

async def async_function():
    await asyncio.sleep(0)
    return 42                   # returns a coroutine object when called

# Calling them:
val = sync_function()           # val = 42  ✓
coro = async_function()         # coro = <coroutine object>  — NOT 42!
val2 = asyncio.run(async_function())  # val2 = 42  ✓

# Common mistake — forgetting await inside async context:
async def bad_example():
    result = async_function()   # BUG: result is a coroutine, not 42
    print(result)               # <coroutine object> — not what you want

async def good_example():
    result = await async_function()   # ✓ result is 42
    print(result)

Example 5 — asyncio.run() internals
pythonimport asyncio

# asyncio.run(coro) does roughly this:
# 1. Creates a new event loop
# 2. Runs the coroutine to completion
# 3. Closes the loop
# It's the standard entry point for asyncio programs.

async def main():
    print("Inside the event loop!")
    await asyncio.sleep(0.1)
    print("Still going...")

# These are equivalent for top-level use:
asyncio.run(main())

# Manual equivalent (don't use in production — just for understanding):
loop = asyncio.new_event_loop()
loop.run_until_complete(main())
loop.close()

